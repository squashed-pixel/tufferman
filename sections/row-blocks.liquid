          "min": 10,
          "max": 100,
          "step": 2,
          "unit": "px",
          "default": 24
        },
        {
          "type": "select",
          "id": "image_max_width",
          "label": "Max Image Width",
          "options": [
            { "value": "25%", "label": "25%" },
            { "value": "33%", "label": "33%" },
            { "value": "50%", "label": "50%" },
            { "value": "100%", "label": "100%" }
          ],
          "default": "100%"
        },
        {
          "type": "header",
          "content": "Text Content"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Block Heading"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "Heading Size",
          "options": [
            { "value": "h1", "label": "H1" },
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" },
            { "value": "h4", "label": "H4" },
            { "value": "h5", "label": "H5" },
            { "value": "h6", "label": "H6" }
          ],
          "default": "h3"
        },
        {
          "type": "checkbox",
          "id": "heading_bold",
          "label": "Make heading bold",
          "default": true
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Add some detail about this block here.</p>"
        },
        {
          "type": "checkbox",
          "id": "description_bold",
          "label": "Make description bold",
          "default": false
        },
        {
          "type": "select",
          "id": "text_alignment",
          "label": "Text Alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "header",
          "content": "Buttons"
        },
        {
          "type": "select",
          "id": "button_position",
          "label": "Button Position",
          "options": [
            { "value": "above", "label": "Above Description" },
            { "value": "below", "label": "Below Description" }
          ],
          "default": "below"
        },
        {
          "type": "range",
          "id": "button_font_size",
          "label": "Button Font Size",
          "min": 10,
          "max": 40,
          "step": 1,
          "unit": "px",
          "default": 16
        },
        {
          "type": "text",
          "id": "button_1_label",
          "label": "Button 1 Label",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "button_1_link",
          "label": "Button 1 Link"
        },
        {
          "type": "color",
          "id": "button_1_bg_color",
          "label": "Button 1 Background",
          "default": "#000000"
        },
        {
          "type": "color",
