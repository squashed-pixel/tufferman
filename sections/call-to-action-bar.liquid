{%- capture section_settings -%}
{
}
{%- endcapture -%}

{%- if section.settings.show_section -%}
<section data-section-id="{{ section.id }}" data-section-type="call-to-action-bar" data-section-settings='{{ section_settings }}' style="background-color: {{ section.settings.background_color }}; margin-top: {{ section.settings.margin_top }}px; margin-bottom: {{ section.settings.margin_bottom }}px; border-top: {{ section.settings.border_top_width }}px solid {{ section.settings.border_top_color }}; border-bottom: {{ section.settings.border_bottom_width }}px solid {{ section.settings.border_bottom_color }};">
  <div class="{% unless section.settings.full_width %}container{% endunless %}">
    <div class="cta-bar__blocks cta-bar__blocks--count-{{ section.blocks.size }}" {% if section.blocks.size > 1 %}data-flickity='{ "watchCSS": true, "cellAlign": "center", "prevNextButtons": false, "pageDots": false, "autoPlay": 2000, "wrapAround": true, "adaptiveHeight": false }'{% endif %}>
      {%- for block in section.blocks -%}
        <div class="cta-bar__block {% if block.settings.link != blank %}cta-bar__block--has-link{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="cta-bar__link"></a>
          {%- endif -%}
          
          <div class="cta-bar__content" style="padding: {{ section.settings.padding_vertical }}px {{ section.settings.padding_horizontal }}px {{ section.settings.padding_vertical }}px {{ section.settings.padding_horizontal }}px;">
            {% if block.type == 'trustpilot_block' %}
              <div class="tp-badge-wrapper" {{ block.shopify_attributes }}>
                {%- comment -%}
                  Accessibility First: We wrap the entire block in a single readable label for screen readers. 
                  Visual elements inside will be hidden from screen readers to prevent confusing, repetitive readouts.
                {%- endcomment -%}
                <div class="tp-badge" aria-label="Rated {{ block.settings.rating_score }} out of 5 stars based on {{ block.settings.review_count }} reviews on Trustpilot.">
                  
                  {%- if block.settings.trustpilot_url != blank -%}
                    <a href="{{ block.settings.trustpilot_url }}" target="_blank" rel="noopener noreferrer" class="tp-badge__link">
                  {%- else -%}
                    <div class="tp-badge__link">
                  {%- endif -%}

                    <!-- 1. Text Label (e.g., "Excellent") -->
                    <span class="tp-badge__label" aria-hidden="true">{{ block.settings.rating_label }}</span>

                    <div class="tp-badge__stars" aria-hidden="true">
                      {%- assign current_score = block.settings.rating_score | plus: 0.0 -%}
                      
                      {%- for i in (1..5) -%}
                        {%- assign half_threshold = i | minus: 0.5 -%}

                        {%- if current_score >= i -%}
                          <svg viewBox="0 0 30 30" width="16" height="16" xmlns="http://www.w3.org/2000/svg">
                            <rect width="30" height="30" fill="#00B67A"/>
                            <path fill="#FFF" d="M15 22.5l-8.8 6.1 3.3-10L.2 12l10.8-1 4-10 4 10 10.8 1-9.3 6.6 3.3 10z"/>
                          </svg>
                        {%- elsif current_score >= half_threshold -%}
                          <svg viewBox="0 0 30 30" width="16" height="16" xmlns="http://www.w3.org/2000/svg">
                            <rect width="15" height="30" fill="#00B67A"/>
                            <rect x="15" width="15" height="30" fill="#DCDCE6"/>
                            <path fill="#FFF" d="M15 22.5l-8.8 6.1 3.3-10L.2 12l10.8-1 4-10 4 10 10.8 1-9.3 6.6 3.3 10z"/>
                          </svg>
                        {%- else -%}
                          <svg viewBox="0 0 30 30" width="16" height="16" xmlns="http://www.w3.org/2000/svg">
                            <rect width="30" height="30" fill="#DCDCE6"/>
                            <path fill="#FFF" d="M15 22.5l-8.8 6.1 3.3-10L.2 12l10.8-1 4-10 4 10 10.8 1-9.3 6.6 3.3 10z"/>
                          </svg>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>

                    <span class="tp-badge__count" aria-hidden="true">
                      {{ block.settings.review_count }} {{ block.settings.review_suffix_text }}
                    </span>

                    <span class="tp-badge__logo" aria-hidden="true">
                      <svg viewBox="0 0 30 30" width="18" height="18" xmlns="http://www.w3.org/2000/svg">
                        <path fill="#00B67A" d="M15 22.5l-8.8 6.1 3.3-10L.2 12l10.8-1 4-10 4 10 10.8 1-9.3 6.6 3.3 10z"/>
                      </svg>
                      <strong>Trustpilot</strong>
                    </span>

                  {%- if block.settings.trustpilot_url != blank -%}
                    </a>
                  {%- else -%}
                    </div>
                  {%- endif -%}
                </div>
              </div>
            {% else %}
            {%- if block.settings.rich_text != blank -%}
              <div class="cta-bar__text rte">
                {{ block.settings.rich_text }}
              </div>
            {%- endif -%}
            
            {%- if block.settings.raw_liquid != blank -%}
              <div class="cta-bar__liquid">
                {{ block.settings.raw_liquid }}
              </div>
            {%- endif -%}
            {% endif %}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .cta-bar__blocks {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    justify-content: center;
  }
  .cta-bar__blocks .trustpilot-widget iframe{
    margin:0!important;
  }
  
  .cta-bar__block {
    position: relative;
    width: 100%;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  
  .cta-bar__link {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
  }
  
  .cta-bar__content {
    width: 100%;
    z-index: 1;
    position: relative;
  }
.cta-bar__text {
    display: flex;
    align-items: center;
    align-content: center;
    justify-content: center;
     min-height: 24px;
}
  .cta-bar__text p {
    margin: 0 !important;
    line-height: 1.2;
    padding: 0 !important;
    align-items: center;
    font-size:{{ section.settings.font_size }}px;
}
  
  .cta-bar__text p + p {
    margin-top: 10px;
  }

  /* Mobile only slideshow */
  @media screen and (max-width: 999px) {
    /* enable Flickity on mobile */
    .cta-bar__blocks:after {
      content: 'flickity';
      display: none;
    }
    
    .cta-bar__blocks {
      display: block; 
    }
    
    .cta-bar__block {
      width: 100%; 
      flex: none;
    }
  }

  @media screen and (min-width: 999px) {
    /* disable Flickity on desktop */
    .cta-bar__blocks:after {
      content: '';
    }

    .cta-bar__blocks--count-1 .cta-bar__block { width: 100%; }
    .cta-bar__blocks--count-2 .cta-bar__block { width: 50%; }
    .cta-bar__blocks--count-3 .cta-bar__block { width: 33.3333%; }
  }

.tp-badge-wrapper {
  display: inline-block;
  font-family: inherit; 
}

.tp-badge__link {
  display: flex;
  align-items: center;
  /* Forces the layout to stay on a single line */
  flex-wrap: nowrap; 
  white-space: nowrap;
  /* Tighter gap between the main elements */
  gap: 8px; 
  text-decoration: none;
  color: inherit;
}

.tp-badge__link:hover {
  text-decoration: none;
}

.tp-badge__label {
  font-size: 0.9rem; /* Scaled down */
  font-weight: 700;
  color: #1a1a1a;
}

.tp-badge__stars {
  display: flex;
  gap: 1px; /* Tighter spacing between stars */
  align-items: center;
}

.tp-badge__count {
  font-size: 0.8rem; /* Scaled down */
  color: #1a1a1a;
}

.tp-badge__logo {
  display: flex;
  align-items: center;
  gap: 3px;
  font-size: 0.85rem; /* Scaled down */
  color: #1a1a1a;
}

.tp-badge__logo strong {
  font-weight: 600;
}
</style>
{%- endif -%}

{% schema %}
{
  "name": "Call to Action Bar",
  "max_blocks": 3,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full Width",
      "default": false,
      "info": "Toggles the page width container on/off."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#f5f5f5"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Margin top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Margin bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Borders"
    },
    {
      "type": "range",
      "id": "border_top_width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Border Top Width",
      "default": 0
    },
    {
      "type": "color",
      "id": "border_top_color",
      "label": "Border Top Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "border_bottom_width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Border Bottom Width",
      "default": 0
    },
    {
      "type": "color",
      "id": "border_bottom_color",
      "label": "Border Bottom Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Block Padding"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top/Bottom Padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Left/Right Padding",
      "default": 20
    },
     {
      "type": "range",
      "id": "font_size",
      "min": 0,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "cta_block",
      "name": "CTA Block",
      "settings": [
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Makes the whole block clickable."
        },
        {
          "type": "richtext",
          "id": "rich_text",
          "label": "Rich Text",
          "default": "<p>Call to action text here</p>"
        },
        {
          "type": "liquid",
          "id": "raw_liquid",
          "label": "Raw Liquid / Embeds",
          "info": "Use this for JavaScript or embeds like Trustpilot."
        }
      ]
    },
    {
      "type": "trustpilot_block",
      "name": "Trustpilot",
      "settings": [
        {
      "type": "text",
      "id": "rating_label",
      "label": "Rating Label",
      "default": "Excellent"
    },
    {
      "type": "range",
      "id": "rating_score",
      "label": "Rating Score",
      "min": 1,
      "max": 5,
      "step": 0.5,
      "default": 4.5
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review Count",
      "default": "16,356"
    },
    {
      "type": "text",
      "id": "review_suffix_text",
      "label": "Text after count",
      "default": "reviews on"
    },
    {
      "type": "url",
      "id": "trustpilot_url",
      "label": "Trustpilot Link",
      "info": "Optional link to your Trustpilot profile."
    }
      ]
    }
  ],
  "presets": [
    {
      "name": "Call to Action Bar",
      "blocks": [
        {
          "type": "cta_block"
        },
        {
          "type": "cta_block"
        },
        {
          "type": "cta_block"
        }
      ]
    }
  ]
}
{% endschema %}
