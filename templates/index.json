    "1658744818c9d7b1e8": {
      "type": "rich-text",
      "settings": {
        "text_width": "wide",
        "text_align": "left",
        "title": "Tufferman Shelving Solutions",
        "content": "<p>Tufferman Ltd is the only distributor of Storalex metal shelving units in the UK and as a result we're able to offer an unrivalled range of storage solutions ranging from heavy duty warehouse and industrial shelving to metal racking, garage shelving and workbenches.<br\/><\/p><p>All Storalex industrial shelving and workbenches are made from high grade, powder coated European steel and use a unique boltless ‘stud & keyhole’ design; which combine to offer excellent levels of rigidity and durability. In addition to this, all of our metal shelving has been tested to strict FEM standards to comply with ISO 9001 quality requirements and come with the much coveted ‘Storalex 5 Year Guarantee’.<br\/><\/p><p>With load capacities per shelf ranging from 200kg to 800kg and shelving units available in a variety of widths, depths and heights, we’re confident that we have a storage solution that’s right for you.<br\/><\/p>",
        "button_text": "",
        "button_link": "shopify:\/\/collections\/all"
      }
    }
