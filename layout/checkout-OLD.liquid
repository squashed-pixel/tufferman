    <title>{{ page_title }}</title>

    {{ content_for_header }}

    {{ checkout_stylesheets }}
    {{ checkout_scripts }}

    {%- if settings.favicon -%}
      <link
        rel="shortcut icon"
        href="{{ settings.favicon | img_url: '96x96' }}"
        type="image/png"
      >
    {%- endif -%}


  </head>

  <body>
    {{ skip_to_content_link }}

    <header
      class="banner"
      data-header
      role="banner"
    >
      <div class="wrap">
        {{ content_for_logo }}
      </div>
    </header>

    {{ order_summary_toggle }}
    <div class="content" data-content>
      <div class="wrap">
        <div class="main">
          <header class="main__header" role="banner">
            {{ content_for_logo }}
            {{ breadcrumb }}
            {{ alternative_payment_methods }}
          </header>
          <main class="main__content" role="main">
            {{ content_for_layout }}
          </main>
          <footer class="main__footer" role="contentinfo">
            {{ content_for_footer }}
          </footer>
        </div>
        <aside class="sidebar" role="complementary">
          <div class="sidebar__header">
            {{ content_for_logo }}
          </div>
          <div class="sidebar__content">
            {{ content_for_order_summary }}
          </div>
        </aside>
      </div>
    </div>

    {% assign delivery_date_picker = settings.delivery_date_picker | split: ', ' | json %}

    {{ tracking_code }}

    <script src="{{ 'checkout.min.js' | asset_url }}"></script>

    <script>
      function insertAfter(newNode, existingNode) {
        existingNode.parentNode.insertBefore(newNode, existingNode.nextSibling);
      }

      if ('{{ checkout.attributes['Event Date'] }}'.length > 0) {
        var selectedDate = '{{ checkout.attributes['Event Date'] }}';
        var cutoff = parseInt('{{ settings.cutoff | json }}');

        var startDay = new Date();
        var deadNextDay = new Date();
        deadNextDay.setDate(deadNextDay.getDate() + 1);
        const deadNextDayFormatted = ("0" + deadNextDay.getDate()).slice(-2) + '/' + ("0" + (deadNextDay.getMonth() + 1)).slice(-2) + '/' + deadNextDay.getFullYear();

        function compareDates(date1, date2) {
          var parts1 = date1.split('/');
          var dateObj1 = new Date(parts1[2], parts1[1] - 1, parts1[0]);
          var parts2 = date2.split('/');
          var dateObj2 = new Date(parts2[2], parts2[1] - 1, parts2[0]);
          return dateObj1.getTime() - dateObj2.getTime();
        }

        if (startDay.getHours() >= cutoff && (compareDates(selectedDate, deadNextDayFormatted) === 0 || compareDates(selectedDate, deadNextDayFormatted) < 0)) {
          window.location = '/cart';
        }
      }

      const shipping_method_step = document.querySelector('div[data-step="shipping_method"]');
      if ('{{ checkout.attributes['Event Date'] }}'.length > 0 && !document.querySelector('#delivery-date') && shipping_method_step) {
        const shipping_method_step_heading = shipping_method_step.querySelector('.section__title');
        const shipping_method_step_subtitle = document.createElement('SPAN');
        shipping_method_step_subtitle.classList.add('section__title__subtitle');
        shipping_method_step_subtitle.setAttribute('id', 'delivery-date')
        shipping_method_step_subtitle.textContent = "Delivery Due: {{ checkout.attributes['Event Date'] }}";
        shipping_method_step_heading.append(shipping_method_step_subtitle);
      }

      const review_methods = document.querySelectorAll(['div[data-step="review"]', 'div[data-step="payment_method"]']);
      for (const review_method of review_methods) {
        if (review_method != undefined) {
          if ('{{ checkout.attributes['Event Date'] }}'.length > 0 && !document.querySelector('#delivery-date-review') && review_method) {
            const review_method_heading = review_method.querySelector('.review-block__content[data-review-section="shipping-cost"]');
            const review_method_subtitle = document.createElement('STONG');
            review_method_subtitle.setAttribute('id', 'delivery-date-review')
            review_method_subtitle.textContent = "Delivery Due: {{ checkout.attributes['Event Date'] }}";
            review_method_heading.append(review_method_subtitle);
          }
        }
      }

      const thank_you = document.querySelector('div[data-step="thank_you"]');
      if ('{{ checkout.attributes['Event Date'] }}'.length > 0 && !document.querySelector('#delivery-date-review') && thank_you) {
        const thank_you_heading = thank_you.querySelector('.content-box:last-of-type .section__content__column:first-of-type');
        const thank_you_subtitle = document.createElement('STONG');
        thank_you_subtitle.setAttribute('id', 'delivery-date-review')
        thank_you_subtitle.textContent = "Delivery Due: {{ checkout.attributes['Event Date'] }}";
        thank_you_heading.append(thank_you_subtitle);
      }

      if (!document.querySelector('#delivery-switcher') && shipping_method_step) {
        const shipping_method_section = shipping_method_step.querySelector('.section--shipping-method')
        const shipping_method_step_change = document.createElement('DIV');
        shipping_method_step_change.classList.add('section__header');
        shipping_method_step_change.setAttribute('id', 'delivery-switcher')
        const shipping_method_step_change_text = document.createElement('P');
        let has_item = false;
        const cart_items = document.querySelectorAll('.product');
        for (let index = 0; index < cart_items.length; index++) {
          const cart_item = cart_items[index];
          if (cart_item.getAttribute('data-product-id') == '7156651294857') {
            has_item = true;
          }
        }
        shipping_method_step_change_text.textContent = has_item ? 'Change to Standard Delivery' : 'Change to Next Day / Selected Delivery';
        const shipping_method_step_change_link = document.createElement('A');
        shipping_method_step_change_link.setAttribute('href', '/cart?id=cart-form&offset=250');
        shipping_method_step_change_link.textContent = 'Click Here';
        shipping_method_step_change.append(shipping_method_step_change_text);
        shipping_method_step_change.append(shipping_method_step_change_link);
        shipping_method_section.append(shipping_method_step_change);
      }
    </script>

    <style>
      .dynamic-checkout,
      .alternative-payment-separator {
        display: none;
      }

      .section--payment-method .section__title {
        white-space: nowrap;
        margin-right: 10px;
      }

      .calendar-button {
        background: #3ab44b;
        color: #fff;
        width: fit-content;
        padding: 10px;
        border-radius: 5px;
        display: flex;
        align-items: center;
        display:none;
        cursor: pointer;
      }

      .mbsc-ios.mbsc-selected .mbsc-calendar-cell-text{
        border-color: #3ab44b;
        background: #3ab44b;
      }

      .mbsc-calendar-controls.mbsc-ios * {
        color: #3ab44b;
      }

      .mbsc-hover .mbsc-calendar-day-text {
        background: #3ab44a77 !important;
      }

      .calendar-button span {
        padding: 0px 20px;
      }

      .calendar-button .breadcrumb__chevron-icon {
        transform: rotate(90deg);
      }

      svg#Capa_1 {
        width: 20px;
      }

      .main .calendar-button .icon-svg--color-adaptive-light {
        color: #fff;
      }

      .calendar-button #Capa_1 path, .calendar-button #Capa_1 rect {
        fill: #fff !important;
      }

      .disabled_button_area {
        width: 183px;
        height: 60px;
        position: absolute;
        background: #ff000024;
        right: 0;
      }

      .section.section--shipping-method {
        margin-bottom: 0px;
      }

      .disabled-border + .field__caret {
        top: 25px;
      }

      .disabled-border-wrapper:after {
        content: "Please answer question";
        color: red;
        margin-top: 7px;
        display: block;
      }

      .main .field__input.disabled-border {
        border: 2px solid red;
      }

      [data-address-field="country"] {
        display: none;
      }

      [data-step="shipping_method"] .step__sections {
        display: flex;
        flex-direction: column;
      }

      .product-table .product__price .order-summary__emphasis {
        display: block;
        text-align: center;
      }

      .display-table .order-summary-toggle__total-recap .total-recap__final-price {
        display: block;
        text-align: center;
      }

      @supports (-webkit-overflow-scrolling: touch) {
        .display-table .order-summary-toggle__total-recap .total-recap__final-price:after {
          content: "";
          display: block;
          font-size: 12px;
          color: #717171;
        }
      }

      tr[data-variant-id="41147543945353"] {
        display: none;
      }

      .shopify-cleanslate ul li:first-of-type,
      .shopify-cleanslate ul div[data-testid="ShopifyPay-button"] {
        display: none !important;
      }

      .section__title__subtitle {
        display: block;
        font-size: 14px;
        margin-top: 10px;
        padding: 5px 10px;
        border: 1px solid black;
      }

      .edit_checkout {
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
      }

      .section--billing-address {
        order: -1;
      }

      .edit_checkout .section {
        margin: 0;
      }

      .review-block__content[data-review-section="shipping-cost"] .small-text {
        display: none;
      }

      #delivery-date-review {
        display: block;
      }

      .review-block__label {
        white-space: nowrap;
      }

      .apple-pay-text {
        margin-top: 10px;
        text-align: center;
      }

      .card-warning {
        display: none;
        text-align: center;
        margin-top: 10px;
        color: red;
        margin-bottom: 20px;
      }

      .alternative-payment-separator,
      .alternative-payment-separator__content {
        display: none;
      }

      @media screen and (max-width: 749px) {
        .review-block__label {
          white-space: nowrap;
        }
      }

      @media screen and (max-width: 1000px) {
        .card-warning {
          display: block;
        }
        .dynamic-checkout {
          display: block;
        }
        .section--contact-information {
          margin-top: 10px;
        }
        .section--contact-information:before {
          text-align: center;
        }
      }
    </style>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-TVW8Z6X"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->

    <script>
      function applePayMessage() {
                if (document.querySelector('li[data-testid="grid-cell"]')) {
                    const new_element = document.createElement('DIV');
                    new_element.setAttribute('class', 'apple-pay-text');
                    new_element.textContent = 'Please check your delivery address before ordering';
                    document.querySelector('li[data-testid="grid-cell"]').closest('.dynamic-checkout__buttons').append(new_element);
                }
            }
      setTimeout(applePayMessage, 3000);

      function cardWarning() {
                if (document.querySelector('.dynamic-checkout')) {
                    const new_element = document.createElement('DIV');
                    new_element.setAttribute('class', 'card-warning');
                    new_element.textContent = 'TO PAY BY DEBIT OR CREDIT CARD PLEASE ENTER YOUR DETAILS BELOW';
                    document.querySelector('.dynamic-checkout').append(new_element);
                }
            }
      setTimeout(cardWarning, 3000);

