{%- comment -%}
  Extract a style from the color swatch config. You must passed two parameters to this snippet:

  - color_swatch_config: extracted from the theme settings
  - value: the actual color
{%- endcomment -%}

{%- assign color_value_downcase = value | downcase -%}
{%- if color_value_downcase contains '/'-%}
  {%- assign first_colour = color_value_downcase | split: '/' | first -%}
  {%- assign second_colour = color_value_downcase | split: '/' | last -%}
  {%- assign color_swatch_style = 'background: linear-gradient(90deg, ' | append: first_colour | append: ' 50%, ' | append: second_colour | append: ' 50%);' -%}
{%- elsif color_value_downcase contains ' & '-%}
  {%- assign first_colour = color_value_downcase | split: ' & ' | first -%}
  {%- assign second_colour = color_value_downcase | split: ' & ' | last -%}
  {%- assign color_swatch_style = 'background: linear-gradient(90deg, ' | append: first_colour | append: ' 50%, ' | append: second_colour | append: ' 50%);' -%}
{%- else -%}
  {% if  color_value_downcase contains "white" %}
    {%- assign color_swatch_style = 'border:1px solid #747474; background-color: ' | append: color_value_downcase -%}
  {% else %}
    {%- assign color_swatch_style = 'background-color: ' | append: color_value_downcase -%}
  {% endif %}
{%- endif -%}

{%- for color_swatch_item in color_swatch_config -%}
  {%- assign color_swatch_parts = color_swatch_item | split: ':' -%}
  {%- assign color_swatch_name = color_swatch_parts.first | downcase | strip -%}

  {%- if color_value_downcase == color_swatch_name -%}
    {%- assign color_swatch_value = color_swatch_parts.last | strip -%}

    {%- if color_swatch_value contains '#' -%}
      {%- assign color_swatch_style = 'background-color: ' | append: color_swatch_value -%}
    {%- elsif images[color_swatch_value] != blank -%}
      {%- assign color_swatch_image = images[color_swatch_value] | img_url: '72x72' -%}
      {%- assign color_swatch_style = 'background-image: url(' | append: color_swatch_image | append: ')' -%}
    {%- endif -%}

    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{{- color_swatch_style -}}