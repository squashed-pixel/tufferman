          <div class="block-swatch">
            <input class="block-swatch__radio product-form__single-selector url-swatch" type="radio" name="{{ option_6 }}" id="{{ option_handle }}-{{ forloop.index }}" value="{{ option | escape }}" data-handle="{{ option | handleize }}" {% if product.handle contains option_handle %}checked{% endif %} data-option-position="{{ option }}-{{ forloop.index }}">
            <label class="block-swatch__item" for="{{ option_handle }}-{{ forloop.index }}" title="{{ option | escape }}">
              <span class="block-swatch__item-text">{{ option }}</span>
            </label>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
{% endif %}