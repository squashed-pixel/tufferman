{%- assign selected_variant = product.selected_or_first_available_variant -%}
{%- assign color_label = 'color,colour,couleur,cor,colore,farbe,색,色,カラー,färg,farve,szín,barva' | split: ',' -%}

{% assign currentVariant = product.metafields.custom.additional_variants_current_product_data.value %}

{% if product.metafields.custom.additional_variant_data_1 != blank and product.metafields.custom.additional_variant_products_1 != blank %}
  <div class="metafield-variants__container">
{% endif %}

  {% if product.metafields.custom.additional_variant_data_1 != blank and product.metafields.custom.additional_variant_products_1 != blank %}
    <!-- Metafield Options - 1 -->
    <div class="metafield_variant_selector {% if product.metafields.custom.additional_variant_title_1 contains "!" %}primary{%- else -%} secondary{%- endif -%}">
      <div class="product-form__option-name__container">
        <span class="product-form__option-name metafield-variant_title" >{{ product.metafields.custom.additional_variant_title_1 | replace: "!", "" }}</span>
        <span class="product-form__option-text">{{ product.metafields.custom.additional_variant_text_1 }}</span>
      </div>

      {% assign cleanTitle = product.metafields.custom.additional_variant_title_1 | downcase %}
      {% if cleanTitle contains "colour" %} {%- assign is_color = true -%}{% else %}{%- assign is_color = false -%}{% endif %}  

      <div class="metafield_variant_items">
        {% for option in product.metafields.custom.additional_variant_products_1.value %}
          {% if product.metafields.custom.additional_variant_data_1.value[forloop.index0] != blank %}
            {%- unless currentVariant contains product.metafields.custom.additional_variant_data_1.value[forloop.index0] %}
              <a href="{{ option.url }}{% if template.suffix == 'custom-template' %}?view=custom-template{%endif %}">
            {% endunless %}
            {% if is_color %}
              <div class="color-swatch {% if downcased_value == 'white' or downcased_value == 'blanc' %}color-swatch--white{% endif %}">
                <input class="color-swatch__radio product-form__single-selector" type="radio" name="{{ option_name }}" id="{{ color_id }}" value="{{ value | escape }}" {% if currentVariant contains product.metafields.custom.additional_variant_data_1.value[forloop.index0] %}checked{% endif %} data-option-position="{{ option.position }}">
                <label class="color-swatch__item" for="{{ color_id }}" style="{% render 'color-swatch-style', color_swatch_config: color_swatch_config, value: product.metafields.custom.additional_variant_data_1.value[forloop.index0] %}" title="{{ product.metafields.custom.additional_variant_data_1.value[forloop.index0] | escape }}">
                  <span class="visually-hidden">{{ value }}</span>
                  {%- render 'icon', icon: 'cross-sold-out' -%}
                </label>
              </div>
            {% else %}
              <div class="block-swatch__item {%- if currentVariant contains product.metafields.custom.additional_variant_data_1.value[forloop.index0] %} block-swatch__item--selected {%- endif -%}">
                <span class="metafield_variant">
                  {{ product.metafields.custom.additional_variant_data_1.value[forloop.index0] }}
                </span>
              </div>
            {% endif %}
            {%- unless currentVariant contains product.metafields.custom.additional_variant_data_1.value[forloop.index0] %}
            </a>
            {% endunless %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endif %}

