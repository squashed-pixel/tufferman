{% if first_time_accessed %}
<!-- Event snippet for Purchase conversion page -->
<script>
  gtag('event', 'conversion', {
    'send_to': 'AW-993295948/l4e1CL_P57cZEMz80dkD',
    'value': {{ checkout.subtotal_price | divided_by: 100.0 }},
    'currency': '{{ currency }}',
    'transaction_id': '{{ order_id }}'
  });
</script>
{% endif %}



<script type="text/javascript">
window.adalyserTracker("trackEvent", "lce3", {value: '{{ order.total_price | money_without_currency }}'}, true);
</script>

<!-- Start of the Sales tracker code (place after LiveChat tracking code) -->
<script type="text/javascript">
var order_id = {{order.order_number}};
var order_sum = {{order.total_price | money_without_currency }};

  var LC_API = LC_API || {on_after_load: function(){}};
  (function(cb){
    LC_API.on_after_load = function(){
      cb();
      try {
        var custom_variables = [
          {name: '__order_id', value: order_id},
          {name: '__order_price', value: order_sum}
        ];
        LC_API.trigger_sales_tracker('TObLrCss2bdhVivFslVnVBAyWVzyWTlp', custom_variables);
      } catch (error) {
        if (window.console){ console.log('LiveChat sales tracker error:', error); }
      }
    };
  })(LC_API.on_after_load);
</script>
<!-- End of the Sales tracker code -->


